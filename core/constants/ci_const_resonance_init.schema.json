{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cimeika.local/schema/ci_const_resonance_init.schema.json",
  "title": "ci_const_resonance_init",
  "description": "JSON Schema for the canonical Cimeika module ci_const_resonance_init.",
  "type": "object",
  "additionalProperties": false,
  "required": ["ci_const_resonance_init"],
  "properties": {
    "ci_const_resonance_init": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "meta",
        "definition",
        "core",
        "principles",
        "phases",
        "required_cycle_fields",
        "states",
        "levels",
        "integrations",
        "security",
        "implementation_minimum",
        "final_statement"
      ],
      "properties": {
        "meta": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "status", "canonical", "required", "language", "type", "scope", "module_role"],
          "properties": {
            "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
            "status": {"type": "string", "enum": ["active", "draft", "deprecated"]},
            "canonical": {"type": "boolean"},
            "required": {"type": "boolean"},
            "language": {"type": "string"},
            "type": {"type": "string", "const": "system_constant"},
            "scope": {"type": "string", "enum": ["global", "module", "local"]},
            "module_role": {"type": "string"}
          }
        },
        "definition": {
          "type": "object",
          "additionalProperties": false,
          "required": ["title", "summary"],
          "properties": {
            "title": {"type": "string", "minLength": 1},
            "summary": {"type": "string", "minLength": 1}
          }
        },
        "core": {
          "type": "object",
          "additionalProperties": false,
          "required": ["formula", "variables", "launch_condition", "deny_condition", "state_transition", "verified_expansion"],
          "properties": {
            "formula": {"type": "string", "minLength": 1},
            "variables": {
              "type": "object",
              "additionalProperties": false,
              "required": ["S", "A", "R", "V", "P", "F", "E", "C"],
              "properties": {
                "S": {"type": "string"},
                "A": {"type": "string"},
                "R": {"type": "string"},
                "V": {"type": "string"},
                "P": {"type": "string"},
                "F": {"type": "string"},
                "E": {"type": "string"},
                "C": {"type": "string"}
              }
            },
            "launch_condition": {"type": "string"},
            "deny_condition": {"type": "string"},
            "state_transition": {"type": "string"},
            "verified_expansion": {"type": "string"}
          }
        },
        "principles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "binary_gate",
            "mode",
            "expansion_rule",
            "growth_rule",
            "relevance_rule",
            "fact_before_expansion",
            "duplicate_noise_block",
            "outdated_context_block",
            "unauthorized_growth_block"
          ],
          "properties": {
            "binary_gate": {"type": "boolean"},
            "mode": {"type": "string"},
            "expansion_rule": {"type": "string"},
            "growth_rule": {"type": "string"},
            "relevance_rule": {"type": "string"},
            "fact_before_expansion": {"type": "boolean"},
            "duplicate_noise_block": {"type": "boolean"},
            "outdated_context_block": {"type": "boolean"},
            "unauthorized_growth_block": {"type": "boolean"}
          }
        },
        "phases": {
          "type": "array",
          "minItems": 7,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "title", "purpose"],
            "properties": {
              "key": {
                "type": "string",
                "enum": [
                  "detect",
                  "authorize",
                  "actualize",
                  "resonance_check",
                  "power_check",
                  "fix",
                  "expand",
                  "recycle"
                ]
              },
              "title": {"type": "string"},
              "purpose": {"type": "string"},
              "checks": {
                "type": "array",
                "items": {"type": "string"}
              },
              "writes": {
                "type": "array",
                "items": {"type": "string"}
              },
              "outputs": {
                "type": "array",
                "items": {"type": "string"}
              }
            },
            "allOf": [
              {
                "if": {"properties": {"key": {"const": "fix"}}},
                "then": {"required": ["writes"]}
              },
              {
                "if": {"properties": {"key": {"enum": ["detect", "authorize", "actualize", "resonance_check", "power_check"]}}},
                "then": {"required": ["checks"]}
              },
              {
                "if": {"properties": {"key": {"enum": ["expand", "recycle"]}}},
                "then": {"required": ["outputs"]}
              }
            ]
          }
        },
        "required_cycle_fields": {
          "type": "array",
          "minItems": 8,
          "items": {"type": "string"}
        },
        "states": {
          "type": "object",
          "additionalProperties": false,
          "required": ["inactive", "detected", "authorized", "actualized", "resonant", "powered", "fixed", "expanded", "recycled", "blocked", "denied"],
          "properties": {
            "inactive": {"type": "string"},
            "detected": {"type": "string"},
            "authorized": {"type": "string"},
            "actualized": {"type": "string"},
            "resonant": {"type": "string"},
            "powered": {"type": "string"},
            "fixed": {"type": "string"},
            "expanded": {"type": "string"},
            "recycled": {"type": "string"},
            "blocked": {"type": "string"},
            "denied": {"type": "string"}
          }
        },
        "levels": {
          "type": "object",
          "additionalProperties": false,
          "required": ["semantic", "administrative"],
          "properties": {
            "semantic": {
              "type": "object",
              "additionalProperties": false,
              "required": ["purpose"],
              "properties": {
                "purpose": {"type": "array", "items": {"type": "string"}, "minItems": 1}
              }
            },
            "administrative": {
              "type": "object",
              "additionalProperties": false,
              "required": ["purpose"],
              "properties": {
                "purpose": {"type": "array", "items": {"type": "string"}, "minItems": 1}
              }
            }
          }
        },
        "integrations": {
          "type": "object",
          "additionalProperties": false,
          "required": ["applies_to"],
          "properties": {
            "applies_to": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string"}
            }
          }
        },
        "security": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rules"],
          "properties": {
            "rules": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string"}
            }
          }
        },
        "implementation_minimum": {
          "type": "object",
          "additionalProperties": false,
          "required": ["checklist"],
          "properties": {
            "checklist": {
              "type": "array",
              "minItems": 8,
              "items": {"type": "string"}
            }
          }
        },
        "final_statement": {"type": "string", "minLength": 1}
      }
    }
  }
}
