# Application Configuration
# Public URL of your deployed application (used by the existing UI and OG routes)
NEXT_PUBLIC_URL=https://ci-moment.vercel.app
# Same URL used by the payment scaffold in lib/payment.ts
NEXT_PUBLIC_APP_URL=https://ci-moment.vercel.app

# Supabase Configuration (legacy — used by existing /api/webhook and /api/seal routes)
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://yksycpmsgljpfzzvqzzw.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Prisma / PostgreSQL Configuration (used by /api/moment/* routes)
# For Supabase: use the "Transaction" connection string from
#   Dashboard → Settings → Database → Connection string → Transaction mode
# Example: postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Payment Configuration
# Controls which payment provider is shown in the legacy UI.
# Options: "gumroad" (default) | "disabled"
NEXT_PUBLIC_PAYMENT_PROVIDER=gumroad

# Stripe Payment Configuration (used by /api/moment/seal when Stripe is connected)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
CI_MOMENT_PRICE_USD=5
